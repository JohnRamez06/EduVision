# Copy this file to .env and fill in your local values.
# .env is gitignored — never commit it.

# ── Database ──────────────────────────────────────────────────────────────────
# Standard MySQL port is 3306. MAMP users: use 8889.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=eduvision

# Spring Boot datasource (uses the values above)
DB_URL=jdbc:mysql://localhost:3306/eduvision?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Change this to a long random string in any shared/production environment
JWT_SECRET=eduvision-secret-change-in-production

# ── Python scripts (enroll_faces.py, auto_enroll_from_photos.py, etc.) ────────
# These read DB_HOST / DB_PORT / DB_USER / DB_PASSWORD / DB_NAME from env
